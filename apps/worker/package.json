{
  "name": "@as-comms/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node ../../scripts/clean-dist.mjs dist && tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "ops:check-config": "tsx src/ops/cli.ts check-config",
    "ops:enqueue": "tsx src/ops/cli.ts enqueue",
    "ops:inspect": "tsx src/ops/cli.ts inspect",
    "lint": "eslint src test --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:unit": "vitest run --config ../../vitest.config.ts --passWithNoTests"
  },
  "dependencies": {
    "@as-comms/contracts": "workspace:*",
    "@as-comms/db": "workspace:*",
    "@as-comms/domain": "workspace:*",
    "@as-comms/integrations": "workspace:*",
    "graphile-worker": "^0.16.6",
    "zod": "^3.24.2"
  }
}
